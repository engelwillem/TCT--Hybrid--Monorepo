
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Data profil pengguna yang terdaftar.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "points": { "type": "number" },
        "level": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "Postingan yang dibagikan oleh pengguna di komunitas.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PostComment": {
      "title": "Post Comment",
      "description": "Komentar pada postingan komunitas.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "text"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Koleksi profil pengguna."
    },
    "/posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Koleksi postingan komunitas."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "PostComment",
      "description": "Sub-koleksi komentar untuk setiap postingan."
    }
  }
}
