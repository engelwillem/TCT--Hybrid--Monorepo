{
  "name": "the-choosen-talks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "dev:tailscale": "next dev --turbopack -H 0.0.0.0 -p 9002",
    "dev:backend": "composer --working-dir backend-api dev",
    "dev:backend:serve": "php backend-api/artisan serve --host=127.0.0.1 --port=8000",
    "dev:backend:tailscale": "php backend-api/artisan serve --host=0.0.0.0 --port=8000",
    "dev:studio": "next dev -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "next build",
    "build:strict-today": "node scripts/build-strict-today.mjs",
    "build:with-encoded-chunk-mirror": "next build && node scripts/mirror-encoded-next-chunks.mjs",
    "start": "next start",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:acceptance": "playwright test tests/renungan-versehub-acceptance.spec.ts",
    "today:readiness:strict": "vitest run src/features/today-ritual/data/today-session.loader.test.ts",
    "zip:website": "python scripts/create_main_website_zip.py",
    "zip:website:clean": "python scripts/create_main_website_zip.py --clean",
    "zip:website:reveal": "python scripts/create_main_website_zip.py --reveal",
    "zip:website:clean:reveal": "python scripts/create_main_website_zip.py --clean --reveal",
    "today:ready": "composer --working-dir backend-api today:ready",
    "today:ready:full": "npm run today:ready && npm run typecheck && npm run test:e2e -- tests/today.smoke.spec.ts",
    "smoke:prod": "powershell -ExecutionPolicy Bypass -File scripts/smoke-production.ps1",
    "smoke:share-assets": "powershell -ExecutionPolicy Bypass -File scripts/smoke-share-assets-prepare.ps1",
    "verify:ai-sharing": "node scripts/verify-ai-sharing.mjs"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.16.1",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tailwindcss/postcss": "^4.0.7",
    "@vercel/og": "^0.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.5.2",
    "firebase": "^11.9.1",
    "framer-motion": "^12.4.7",
    "genkit": "^1.34.0",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.5.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^4.0.7",
    "wav": "^1.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.17.19",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
