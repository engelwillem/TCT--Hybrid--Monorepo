APP_NAME=TheChosenTalks
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_URL=http://localhost:9002
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SOCKET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@thechoosentalks.org"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# UI / Branding (safe to expose to frontend)
UI_COMMUNITY_NAME="The Chosen People"
UI_BRAND_HSL="201 100% 50%"
UI_BRAND_FOREGROUND_HSL="0 0% 8%"
UI_DEMO_USER_NAME="Chosen People"
UI_DEMO_USER_EMAIL="info@thechoosentalks.org"
UI_DEMO_USER_AVATAR_URL="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=200&auto=format&fit=crop"

# Official wordmark/tagline + website
UI_TAGLINE="The Chosen People"
UI_OFFICIAL_DOMAIN="https://www.thechoosentalks.org"

# Admin hardening
ADMIN_ALERT_EMAIL=
ADMIN_PASSWORD_RESET_EMAIL=
BOOTSTRAP_ADMIN_EMAILS=engel.willem@gmail.com

# CORS (optional)
# Comma-separated allowlist of origins.
# Local parity example:
# CORS_ALLOWED_ORIGINS=http://localhost:9002,http://127.0.0.1:9002
# Production parity example:
# CORS_ALLOWED_ORIGINS=https://www.thechoosentalks.org,https://thechoosentalks.org
CORS_ALLOWED_ORIGINS=
CORS_SUPPORTS_CREDENTIALS=false

# Sanctum / SPA parity
# Local example:
# SANCTUM_STATEFUL_DOMAINS=localhost:9002,127.0.0.1:9002
# Production example:
# SANCTUM_STATEFUL_DOMAINS=www.thechoosentalks.org,thechoosentalks.org
SANCTUM_STATEFUL_DOMAINS=

# Firebase token verification for decoupled Next.js frontend.
# Use the same Firebase project as the frontend and production.
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=

# Zero-downtime deploy hardening
DEPLOY_TOKEN=
# Comma-separated allowlist of IPs. Leave default to restrict to server only.
DEPLOY_ALLOWED_IPS=127.0.0.1,::1

# Local deploy helper (deploy-local.js)
FTP_HOST=
FTP_USER=
FTP_PASS=
SERVER_URL=

# Optional: trigger deploy via SSH
SSH_HOST=
SSH_USER=
SSH_PORT=22
SSH_KEY_PATH=

# VerseHub OG font pin (relative path from project root).
# Keep this pinned to bundled assets for deploy consistency.
VERSEHUB_OG_FONT=resources/fonts/og/VerseHubBrand-Regular.ttf
