{
  "id": null,
  "uid": "tct-operational-mvp",
  "title": "TCT Operational MVP",
  "tags": [
    "tct",
    "operational",
    "mvp"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "p95 Latency (HTTP Probes, 5m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.95, probe_duration_seconds{job=\"blackbox-http\"}[5m])",
          "legendFormat": "{{target_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate % (HTTP Probes, 5m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - avg_over_time(probe_success{job=\"blackbox-http\"}[5m])) * 100",
          "legendFormat": "{{target_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "HTTP Status Code (Current)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_http_status_code{job=\"blackbox-http\"}",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Containers Up",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(probe_success{job=\"blackbox-tcp\"} == 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Containers Down",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(probe_success{job=\"blackbox-tcp\"} == 0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Container Up/Down (TCP Probe)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{job=\"blackbox-tcp\"}",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "SLO Availability (30m %)",
      "gridPos": {
        "y": 20,
        "x": 0,
        "h": 4,
        "w": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(probe_success{job=\"blackbox-http\"}[30m]) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 99,
                "color": "orange"
              },
              {
                "value": 99.5,
                "color": "green"
              }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "SLO Error Budget Burn (30m %)",
      "gridPos": {
        "y": 20,
        "x": 6,
        "h": 4,
        "w": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - avg_over_time(probe_success{job=\"blackbox-http\"}[30m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 0.5,
                "color": "orange"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Error Rate % (30m)",
      "gridPos": {
        "y": 24,
        "x": 0,
        "h": 8,
        "w": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - avg_over_time(probe_success{job=\"blackbox-http\"}[30m])) * 100",
          "legendFormat": "{{target_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true,
          "displayMode": "table"
        }
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Active Alerts (Firing)",
      "gridPos": {
        "y": 20,
        "x": 12,
        "h": 8,
        "w": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ALERTS{alertstate=\"firing\"}",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ]
}
