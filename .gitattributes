# Normalize Newlines
* text=auto eol=lf
*.ps1 text eol=crlf
*.sh text eol=lf
*.md text eol=lf

# Binary Files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.sql binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Export Cleanup (exclude non-runtime assets from archive/export)
docs/ export-ignore
node_modules/ export-ignore
.next/ export-ignore
.next-stale-*/ export-ignore
.npm-cache/ export-ignore
.playwright-mcp/ export-ignore
.idx/ export-ignore
.codex/ export-ignore
tmp/ export-ignore
tmp-*/ export-ignore
tmp_*/ export-ignore
test-results/ export-ignore
deliverables/ export-ignore
backups/ export-ignore

backend-api/vendor/ export-ignore
