# Normalize Newlines (Standard for Firebase/Linux)
* text=auto eol=lf
*.ps1 text eol=crlf
*.sh text eol=lf
*.md text eol=lf

# Binary Files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.sql binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

