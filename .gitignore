# 1. Base Ignores
node_modules/
.next/
out/
build/
.DS_Store
*.log
*.tmp
*.tsbuildinfo
tsconfig.tsbuildinfo

# 2. Environment & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
auth.json

# 3. Local Backend & Documentation (DO NOT COMMIT)
/backend-api/
/docs/
/*.md
!/README.md
/componentss.json
/components.json
/response.html
/ERROR FIREBASE STUDIO.md

# 4. Whitelist Essential Next.js Files (FOR COMMIT)
!/src/
!/public/
!/package.json
!/package-lock.json
!/tsconfig.json
!/next.config.ts
!/next-env.d.ts
!/apphosting.yaml
!/postcss.config.mjs
!/.gitignore
!/.gitattributes

# 5. OS/IDE Specific
.idx/
.vscode/
.idea/
.npm-cache
.modified
