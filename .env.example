APP_NAME=TheChosenTalks
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# For cPanel atomic deploy, point this to shared path to keep users persistent across releases.
# Example: DB_DATABASE=/home/<cpanel_user>/deploy/apps/thechoosentalks/shared/database/database.sqlite
# DB_DATABASE=/home/<cpanel_user>/deploy/apps/thechoosentalks/shared/database/database.sqlite
#
# MySQL / MariaDB (cPanel) example:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=<cpanel_user>_thechoosentalks
# DB_USERNAME=<cpanel_user>_tct_user
# DB_PASSWORD=
# DB_SOCKET=
#
# Temporary source path for one-time SQLite -> MySQL migration command:
# php artisan db:migrate-sqlite-to-mysql --truncate
# SQLITE_LEGACY_DATABASE=/home/<cpanel_user>/deploy/apps/thechoosentalks/shared/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@thechoosentalks.org"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# UI / Branding (safe to expose to frontend)
UI_COMMUNITY_NAME="The Chosen People"
UI_BRAND_HSL="201 100% 50%"
UI_BRAND_FOREGROUND_HSL="0 0% 8%"
UI_DEMO_USER_NAME="Chosen People"
UI_DEMO_USER_EMAIL="info@thechoosentalks.org"
UI_DEMO_USER_AVATAR_URL="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=200&auto=format&fit=crop"

# Official wordmark/tagline + website
UI_TAGLINE="The Chosen People"
UI_OFFICIAL_DOMAIN="https://www.thechoosentalks.org"

# Admin hardening
ADMIN_ALERT_EMAIL=
ADMIN_PASSWORD_RESET_EMAIL=
BOOTSTRAP_ADMIN_EMAILS=engel.willem@gmail.com

# CORS (optional)
# Comma-separated allowlist of origins.
CORS_ALLOWED_ORIGINS=

# Zero-downtime deploy hardening
DEPLOY_TOKEN=
# Comma-separated allowlist of IPs. Leave default to restrict to server only.
DEPLOY_ALLOWED_IPS=127.0.0.1,::1

# Local deploy helper (deploy-local.js)
FTP_HOST=
FTP_USER=
FTP_PASS=
SERVER_URL=

# Optional: trigger deploy via SSH
SSH_HOST=
SSH_USER=
SSH_PORT=22
SSH_KEY_PATH=
MIGRATE_SQLITE_TO_MYSQL_ON_DEPLOY=0

# VerseHub OG font pin (relative path from project root).
# Keep this pinned to bundled assets for deploy consistency.
VERSEHUB_OG_FONT=resources/fonts/og/VerseHubBrand-Regular.ttf
