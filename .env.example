# Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:9002
NEXT_PUBLIC_TCT_COMMUNITY_URL=https://www.thechoosentalks.org/portfolio1
NEXT_PUBLIC_TCT_WA_URL=https://www.thechoosentalks.org/portfolio2
NEXT_PUBLIC_TCT_AIOS_URL=https://www.thechoosentalks.org/portfolio3

# Laravel API origin (cPanel backend)
# Used by Next.js route handlers (/api/*) to proxy data requests.
# Local parity target: use the same backend origin you will run for Laravel locally.
# Production parity target: point to the cPanel Laravel origin, not the Tencent Pages URL.
LARAVEL_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_LARAVEL_API_BASE_URL=http://127.0.0.1:8000

# /today-v2 local integration (optional)
# If TODAY_V2_SESSION_ENDPOINT is empty, frontend derives:
#   {LARAVEL_API_BASE_URL}/api/today-v2/session
TODAY_V2_SESSION_ENDPOINT=
TODAY_V2_SESSION_TIMEOUT_MS=4500
TODAY_V2_SESSION_REVALIDATE_SECONDS=300
TODAY_V2_STRICT_INTEGRATION=false
TODAY_V2_INTEGRATION_TRACE=false

# /renungan daily artifact cache (Phase 2 reliability)
# Production should keep adapter=laravel and configure TODAY_SESSION_ARTIFACT_TOKEN.
TODAY_SESSION_CACHE_ADAPTER=laravel
TODAY_SESSION_CACHE_ALLOW_MEMORY_FALLBACK=true
TODAY_SESSION_CACHE_TTL_SECONDS=900
TODAY_SESSION_CACHE_MAX_AGE_DAYS=3
TODAY_SESSION_BACKGROUND_REFRESH_COOLDOWN_MS=60000
TODAY_SESSION_ARTIFACT_TOKEN=
TODAY_WARM_TOKEN=

# Firebase (client)
# These values must match the same Firebase project used by production.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# E2E acceptance (Auth + Privacy + Renungan -> VerseHub)
# Primary recommended variables:
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_MEMBER_A_EMAIL=
E2E_MEMBER_A_PASSWORD=
E2E_MEMBER_B_EMAIL=
E2E_MEMBER_B_PASSWORD=

# Optional aliases supported by tests:
E2E_ADMIN_USER_EMAIL=
E2E_ADMIN_USER_PASSWORD=
E2E_MEMBER_EMAIL=
E2E_MEMBER_PASSWORD=
E2E_MEMBER_SECONDARY_EMAIL=
E2E_MEMBER_SECONDARY_PASSWORD=

# Legacy fallback (member A fallback when variables above are unset):
E2E_AUTH_EMAIL=
E2E_AUTH_PASSWORD=
